{
    "compilerOptions": {
        "target": "es2022",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "verbatimModuleSyntax": false,
        "noEmit": false,
        "strict": true,
        "outDir": "dist",
        "rootDir": "src",
        "skipLibCheck": true,
    },
    "include": ["src/**/*"],
    "exclude": ["**/*.test.ts"],
}